# =============================================================================
# Shop31 — змінні для СЕРВЕРА оплати (каталог server/). Файл .env тут, не в корені.
# Довідник проєкту: ../docs/СТРУКТУРА-ПРОЄКТУ.md
# =============================================================================
#
# Скопіюйте як server/.env (не комітити .env у git).
# Ключі: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# У корені фронта (.env): VITE_STRIPE_PUBLISHABLE_KEY=pk_test_... (для форми оплати на сайті)
# Webhook secret (Stripe Dashboard → Developers → Webhooks):
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Куди йдуть гроші:
# — Без рядка нижче: баланс того Stripe-акаунту, з якого sk_... (у Dashboard → виплати на ВАШ банк).
# — З Stripe Connect: ід підключеного акаунту acct_... — платежі зараховуються на ЙОГО баланс
#   (виплати на банк/карту, прив’язані в ЙОГО акаунті). Потрібен увімкнений Connect на платформі.
# STRIPE_CONNECTED_ACCOUNT_ID=acct_xxxxxxxxxxxxxxxx
#
# Опційно:
# PORT=4242

# --- Postgres (реальна адмінка/користувачі/замовлення) ---
# Вкажіть свій Postgres connection string:
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?schema=public"
#
# Локально через docker-compose (server/docker-compose.yml):
# DATABASE_URL="postgresql://shop31:shop31@127.0.0.1:5432/shop31?schema=public"
#
# Секрет для JWT (будь-який довгий рядок):
# JWT_SECRET="change_me_to_long_random_string"
#
# Створити admin при старті (один раз, якщо такого email ще немає):
# SEED_ADMIN_EMAIL="admin@shop31.local"
# SEED_ADMIN_PASSWORD="ChangeMe123!"
# SEED_ADMIN_NAME="Administrator"

# --- LiqPay ---
# Ключі LiqPay (кабінет LiqPay): public_key + private_key
# LIQPAY_PUBLIC_KEY=
# LIQPAY_PRIVATE_KEY=
