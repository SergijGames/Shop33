# =============================================================================
# Shop31 — зразок змінних середовища для ФРОНТЕНДУ (корінь репозиторію).
# Скопіюйте в .env у корені або перейменуйте цей файл. Після зміни — перезапуск
# `npm run dev` або повторна збірка `npm run build` (Vite підставляє змінні в bundle).
# Детальніше: docs/СТРУКТУРА-ПРОЄКТУ.md
# =============================================================================
#
# EmailJS — https://www.emailjs.com/ (безкоштовний тариф для тестів)
#
# 1) Зареєструйтесь, створіть Email Service (Gmail тощо) і Template.
# 2) У шаблоні обов’язково: «To Email» = {{user_email}} (не статична адреса).
#    У тілі: {{email_intro}} (перший рядок), {{thank_you_text}}, {{user_name}}, {{email_subject}}.
# 3) Скопіюйте Public Key, Service ID, Template ID сюди.
# 4) Перейменуйте цей файл у .env або скопіюйте рядки в .env у корені Shop31.
# 5) Після зміни .env: перезапустіть `npm run dev` або знову `npm run build`
#    (Vite підставляє змінні під час збірки — для preview/dist потрібна нова збірка).
#
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
# Опційно: окремий шаблон для листа «замовлення підтверджено» (якщо пусто — той самий VITE_EMAILJS_TEMPLATE_ID).
# У шаблоні можна додати змінні order_id, order_summary, payment_label (разом із user_email, thank_you_text тощо).
# VITE_EMAILJS_TEMPLATE_ORDER_ID=

# Опційно: адмін-панель (якщо не задано — значення з коду)
# VITE_ADMIN_EMAIL=
# VITE_ADMIN_PASSWORD=

# --- Stripe (оплата карткою на сайті) + URL API ---
# Увімкнути блок оплати на checkout: true / false
# VITE_STRIPE_CHECKOUT_ENABLED=true
# Публічний ключ із Stripe Dashboard (pk_test_... або pk_live_...)
# VITE_STRIPE_PUBLISHABLE_KEY=
# Якщо API не на тому ж origin (рідко в dev): базовий URL без завершального /
# VITE_PAYMENT_API_URL=http://127.0.0.1:4242

# --- LiqPay ---
# Показати кнопку оплати LiqPay на checkout:
# VITE_LIQPAY_ENABLED=true
